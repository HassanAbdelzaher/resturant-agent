# ============================================================
# مطعم أبو طبق — WhatsApp Agent  |  Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ============================================================

# ── GreenAPI WhatsApp Gateway ────────────────────────────────
# Create a free instance at https://green-api.com
# Then copy idInstance and apiTokenInstance from your dashboard.
GREENAPI_ID_INSTANCE=1101234567
GREENAPI_API_TOKEN=your_api_token_here
GREENAPI_API_URL=https://7105.api.greenapi.com    # use your instance's subdomain
GREENAPI_MEDIA_URL=https://7105.media.greenapi.com

# ── LLM Provider — pick ONE ──────────────────────────────────
LLM_PROVIDER=anthropic          # "anthropic" or "openai"
ANTHROPIC_API_KEY=sk-ant-...    # https://console.anthropic.com/
OPENAI_API_KEY=sk-...           # https://platform.openai.com/  (only needed if LLM_PROVIDER=openai)

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/restaurant_bot

# ── PDF RAG (supplementary documents) ────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
PDF_DIRECTORY=./pdfs

# ── MCP ──────────────────────────────────────────────────────
MCP_TRANSPORT=stdio             # keep as "stdio" for local MCP servers

# ── App ──────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true                      # set to "false" in production
